local function switchTab(tab)
    State.CurrentTab = tab
    searchBar.Visible = (tab == "Search")
    scroll.Position = (tab == "Search") and UDim2.new(0, 10*SF, 0, 305*SF) or UDim2.new(0, 10*SF, 0, 260*SF)
    scroll.Size = (tab == "Search") and UDim2.new(1, -20*SF, 0, 145*SF) or UDim2.new(1, -20*SF, 0, 185*SF)
    if tab == "Recommend" then render(Recommends)
    elseif tab == "Favorite" then render(State.Favorites)
    elseif tab == "Search" then render({}) end
end

