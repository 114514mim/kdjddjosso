-- 播放核心逻辑
local function play(id, name)
    if State.Sound then State.Sound:Destroy() end
    State.IsPlaying = true
    State.IsPaused = false
    info.Text = name
    playBtn.Text = "⏸"
    cover.Image = "rbxthumb://type=Asset&id="..id.."&w=150&h=150"
    
    local s = Instance.new("Sound", SoundService)
    s.SoundId = "rbxassetid://"..id
    s.Volume = 2
    s:Play()
    State.Sound = s
    s.Ended:Connect(function() State.IsPlaying = false; playBtn.Text = "▶" end)
end

playBtn.MouseButton1Click:Connect(function()
    if not State.Sound then return end
    if State.IsPaused then State.Sound:Resume(); State.IsPaused = false; playBtn.Text = "⏸"
    else State.Sound:Pause(); State.IsPaused = true; playBtn.Text = "▶" end
end)

local function render(data)
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for i, item in pairs(data) do
        local row = create("Frame", {Size = UDim2.new(1, -5, 0, 35), BackgroundColor3 = C.panel, Parent = scroll})
        corner(row, 4)
        create("TextLabel", {Size = UDim2.new(1, -80, 1, 0), Position = UDim2.new(0, 8, 0, 0), Text = item.name, TextColor3 = C.text, Font = "Gotham", TextSize = 11, BackgroundTransparency = 1, TextXAlignment = "Left", Parent = row})
        
        local p = create("TextButton", {Size = UDim2.new(0, 25, 0, 25), Position = UDim2.new(1, -30, 0.5, -12), Text = "▶", BackgroundColor3 = C.accent, TextColor3 = C.text, Parent = row})
        corner(p, 4)
        p.MouseButton1Click:Connect(function() State.CurrentList = data; State.Index = i; play(item.id, item.name) end)

        local f = create("TextButton", {Size = UDim2.new(0, 25, 0, 25), Position = UDim2.new(1, -60, 0.5, -12), Text = "❤", BackgroundColor3 = C.card, TextColor3 = C.error, Parent = row})
        corner(f, 4)
        f.MouseButton1Click:Connect(function() table.insert(State.Favorites, item); save(); f.Text = "✔" end)
    end
end

-- 搜索逻辑 (使用记录的 AssetService)
sGo.MouseButton1Click:Connect(function()
    local kw = input.Text
    if kw == "" then return end
    sGo.Text = "..."
    local params = Instance.new("AudioSearchParams")
    params.SearchKeyword = kw
    local success, res = pcall(function() return AssetService:SearchAudio(params) end)
    if success then
        local found = {}
        for _, v in pairs(res:GetCurrentPage()) do table.insert(found, {id=v.Id, name=v.Title}) end
        render(found)
    end
    sGo.Text = "🔍"
end)

