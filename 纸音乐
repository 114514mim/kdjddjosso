-- 数据存储
local SAVE_PATH = "PaperMusic_Data.json"
local State = {
    Favorites = {},
    CurrentList = {},
    Index = 1,
    IsPlaying = false,
    IsPaused = false,
    Sound = nil,
    Minimized = false
}

local function load()
    pcall(function()
        if isfile(SAVE_PATH) then State.Favorites = HttpService:JSONDecode(readfile(SAVE_PATH)) end
    end)
end
local function save()
    pcall(function() writefile(SAVE_PATH, HttpService:JSONEncode(State.Favorites)) end)
end
load()

local function create(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do if k ~= "Parent" then o[k] = v end end
    o.Parent = props.Parent
    return o
end

local function corner(p, r) create("UICorner", {CornerRadius = UDim.new(0, r or 8), Parent = p}) end

