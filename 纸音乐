if not game:IsLoaded() then game.Loaded:Wait() end
local env = getgenv and getgenv() or _G
local FLAG = "_PAPER_MUSIC_V4_CORE_"
if env[FLAG] then env[FLAG].Gui:Destroy() end

local service = setmetatable({}, {__index = function(self, n) return game:GetService(n) end})
local AssetService = service.AssetService
local SoundService = service.SoundService
local HttpService = service.HttpService
local RunService = service.RunService
local UserInputService = service.UserInputService

local IsMobile = UserInputService.TouchEnabled
local UIScale = IsMobile and 0.85 or 1

local C = {
    bg = Color3.fromRGB(22, 22, 26),
    accent = Color3.fromRGB(0, 170, 255),
    text = Color3.fromRGB(255, 255, 255),
}

local State = { IsPlaying = false, IsPaused = false, Sound = nil }

local function create(cls, props)
    local o = Instance.new(cls)
    for k, v in pairs(props) do if k ~= "Parent" then o[k] = v end end
    o.Parent = props.Parent
    return o
end

-- GUI 核心
local gui = create("ScreenGui", {Name = "PaperMusic_Gui", Parent = service.CoreGui, ResetOnSpawn = false})
env[FLAG] = {Gui = gui}

-- [[ 新增：全屏歌词显示层 ]]
local lyricFrame = create("Frame", {
    Size = UDim2.new(1, 0, 0, 80),
    Position = UDim2.new(0, 0, 1, -120), -- 位于屏幕底部上方一点
    BackgroundTransparency = 1,
    Parent = gui
})

local lyricText = create("TextLabel", {
    Size = UDim2.new(1, 0, 1, 0),
    Text = "",
    Font = "GothamBold",
    TextSize = IsMobile and 24 or 32,
    TextColor3 = C.text,
    TextStrokeTransparency = 0, -- 开启描边
    TextStrokeColor3 = Color3.new(0,0,0),
    BackgroundTransparency = 1,
    Parent = lyricFrame
})

-- 歌词更新逻辑
local function updateLyric(txt)
    lyricText.Text = txt
    lyricText.GroupTransparency = 1
    -- 简单的淡入效果
    task.spawn(function()
        for i = 1, 0, -0.1 do
            lyricText.TextTransparency = i
            lyricText.TextStrokeTransparency = i
            task.wait(0.05)
        end
    end)
end

-- 主面板 (保持原样)
local baseWidth, baseHeight = 340 * UIScale, 480 * UIScale
local main = create("Frame", {
    Size = UDim2.new(0, baseWidth, 0, baseHeight), 
    Position = UDim2.new(0.5, -baseWidth/2, 0.5, -baseHeight/2), 
    BackgroundColor3 = C.bg, 
    Parent = gui
})
Instance.new("UICorner", main).CornerRadius = UDim.new(0, 12)

-- 播放核心逻辑 (接入歌词)
local function play(id, name)
    if State.Sound then State.Sound:Destroy() end
    State.IsPlaying = true
    State.IsPaused = false
    
    -- 在屏幕中央显示歌词提示
    updateLyric("正在播放: " .. name)
    
    local s = Instance.new("Sound", SoundService)
    s.SoundId = "rbxassetid://" .. id
    s.Volume = 2
    s:Play()
    State.Sound = s
    
    -- 模拟歌词随播放阶段变化 (示例)
    task.delay(3, function()
        if State.Sound and State.Sound.IsPlaying then
            updateLyric("♪ ——— " .. name .. " ——— ♪")
        end
    end)

    s.Ended:Connect(function()
        State.IsPlaying = false
        updateLyric("") -- 清空歌词
    end)
end

