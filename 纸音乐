-- --- 播放核心逻辑 ---
local function playAt(index)
    if #State.CurrentList == 0 then return end
    State.Index = math.clamp(index, 1, #State.CurrentList)
    local song = State.CurrentList[State.Index]
    if song then _G.PlayMusic(song.id, song.name) end
end

local function playNext()
    if State.LoopMode == 2 then -- 随机
        playAt(math.random(1, #State.CurrentList))
    else
        local nextIdx = State.Index + 1
        if nextIdx > #State.CurrentList then nextIdx = 1 end
        playAt(nextIdx)
    end
end

_G.PlayMusic = function(id, name)
    if State.Sound then State.Sound:Destroy() end
    State.IsPlaying = true; State.IsPaused = false; playBtn.Text = "⏸"; info.Text = name
    cover.Image = "rbxthumb://type=Asset&id="..id.."&w=150&h=150"
    local s = Instance.new("Sound", SoundService)
    s.SoundId = "rbxassetid://"..id; s.Volume = 2; s:Play()
    State.Sound = s
    s.Ended:Connect(function()
        if State.LoopMode == 1 then _G.PlayMusic(id, name) else playNext() end
    end)
end

playBtn.MouseButton1Click:Connect(function()
    if not State.Sound then return end
    if State.IsPaused then State.Sound:Resume(); State.IsPaused = false; playBtn.Text = "⏸"
    else State.Sound:Pause(); State.IsPaused = true; playBtn.Text = "▶" end
end)

prevBtn.MouseButton1Click:Connect(function()
    local prevIdx = State.Index - 1
    if prevIdx < 1 then prevIdx = #State.CurrentList end
    playAt(prevIdx)
end)
nextBtn.MouseButton1Click:Connect(playNext)

