local function toggleUI(isMinimize)
    State.Minimized = isMinimize
    if isMinimize then
        toggleBtn.Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset - 60, main.Position.Y.Scale, main.Position.Y.Offset + 10)
        main.Visible = false
        toggleBtn.Visible = true
    else
        main.Visible = true
        toggleBtn.Visible = false
    end
end

