local function render(data)
    for _, v in pairs(scroll:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    for i, item in pairs(data) do
        local row = create("Frame", {Size = UDim2.new(1, -5, 0, 40*SF), BackgroundColor3 = C.panel, Parent = scroll})
        corner(row, 6)
        create("TextLabel", {Size = UDim2.new(1, -100*SF, 1, 0), Position = UDim2.new(0, 10*SF, 0, 0), Text = item.name, TextColor3 = C.text, Font = "Gotham", TextSize = 11*SF, BackgroundTransparency = 1, TextXAlignment = "Left", Parent = row})

        local p = create("TextButton", {Size = UDim2.new(0, 30*SF, 0, 30*SF), Position = UDim2.new(1, -40*SF, 0.5, -15*SF), Text = "▶", BackgroundColor3 = C.accent, Parent = row})
        corner(p, 6)
        p.MouseButton1Click:Connect(function() State.CurrentList = data; State.Index = i; _G.PlayMusic(item.id, item.name) end)

        local isFav = false
        for _, f in pairs(State.Favorites) do if f.id == item.id then isFav = true break end end
        local fv = create("TextButton", {Size = UDim2.new(0, 30*SF, 0, 30*SF), Position = UDim2.new(1, -75*SF, 0.5, -15*SF), Text = isFav and "❤" or "♡", TextColor3 = C.fav, BackgroundTransparency = 1, TextSize = 16*SF, Parent = row})
        fv.MouseButton1Click:Connect(function()
            if isFav then
                for idx, f in pairs(State.Favorites) do if f.id == item.id then table.remove(State.Favorites, idx) break end end
                fv.Text = "♡"
            else
                table.insert(State.Favorites, {id = item.id, name = item.name})
                fv.Text = "❤"
            end
            isFav = not isFav; saveFavs()
            if State.CurrentTab == "Favorite" then render(State.Favorites) end
        end)
    end
end

