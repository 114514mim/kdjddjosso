local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- --- 核心变量 ---
local Flying = false
local Speed = 80
local bv, bg, connection

-- --- 核心功能函数 ---
local function cleanup()
    if connection then connection:Disconnect() end
    if bv then bv:Destroy(); bv = nil end
    if bg then bg:Destroy(); bg = nil end
    local char = LocalPlayer.Character
    if char and char:FindFirstChildOfClass("Humanoid") then
        char:FindFirstChildOfClass("Humanoid").PlatformStand = false
    end
end

local function startVFly()
    cleanup()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char:WaitForChild("Humanoid")
    local camera = workspace.CurrentCamera
    
    local function getTarget()
        return (hum.SeatPart and hum.SeatPart:IsA("BasePart") and hum.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    end

    local target = getTarget()
    if not target then return end

    bv = Instance.new("BodyVelocity", target)
    bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bg = Instance.new("BodyGyro", target)
    bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)

    connection = RunService.RenderStepped:Connect(function()
        if not Flying or hum.Health <= 0 then cleanup(); return end
        
        local currentTarget = getTarget()
        if currentTarget and bv.Parent ~= currentTarget then
            bv.Parent = currentTarget
            bg.Parent = currentTarget
        end

        bg.CFrame = camera.CFrame
        if hum.MoveDirection.Magnitude > 0 then
            bv.Velocity = camera.CFrame.LookVector * Speed
        else
            bv.Velocity = Vector3.new(0, 0, 0)
        end
        
        -- 同步载具原生速度（如果是车）
        if hum.SeatPart and hum.SeatPart:IsA("VehicleSeat") then
            hum.SeatPart.MaxSpeed = Speed
            hum.SeatPart.Torque = 10000
        end
    end)
end

-- --- UI 构建 ---
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "VFly_Mobile_UI"
ScreenGui.ResetOnSpawn = false

local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 160, 0, 180)
Frame.Position = UDim2.new(0.5, -80, 0.1, 0)
Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Frame.BackgroundTransparency = 0.3
Frame.Active = true
Frame.Draggable = true -- 手机端可拖动

local UICorner = Instance.new("UICorner", Frame)

local Title = Instance.new("TextLabel", Frame)
Title.Text = "VFLY CONTROL"
Title.Size = UDim2.new(1, 0, 0, 30)
Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundTransparency = 1
Title.Font = Enum.Font.GothamBold

-- 飞行开关按钮
local FlyBtn = Instance.new("TextButton", Frame)
FlyBtn.Name = "纸飞车"
FlyBtn.Text = "OFF"
FlyBtn.Size = UDim2.new(0.8, 0, 0, 35)
FlyBtn.Position = UDim2.new(0.1, 0, 0.2, 0)
FlyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
Instance.new("UICorner", FlyBtn)

-- 速度显示
local SpeedLabel = Instance.new("TextLabel", Frame)
SpeedLabel.Text = "Speed: " .. Speed
SpeedLabel.Size = UDim2.new(1, 0, 0, 20)
SpeedLabel.Position = UDim2.new(0, 0, 0.45, 0)
SpeedLabel.TextColor3 = Color3.new(1, 1, 1)
SpeedLabel.BackgroundTransparency = 1

-- 加速按钮
local AddBtn = Instance.new("TextButton", Frame)
AddBtn.Text = "+"
AddBtn.Size = UDim2.new(0.35, 0, 0, 30)
AddBtn.Position = UDim2.new(0.1, 0, 0.6, 0)
AddBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
Instance.new("UICorner", AddBtn)

-- 减速按钮
local MinusBtn = Instance.new("TextButton", Frame)
MinusBtn.Text = "-"
MinusBtn.Size = UDim2.new(0.35, 0, 0, 30)
MinusBtn.Position = UDim2.new(0.55, 0, 0.6, 0)
MinusBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
Instance.new("UICorner", MinusBtn)

-- 重置状态按钮 (防止死后卡住)
local ResetBtn = Instance.new("TextButton", Frame)
ResetBtn.Text = "RESET STATUS"
ResetBtn.Size = UDim2.new(0.8, 0, 0, 25)
ResetBtn.Position = UDim2.new(0.1, 0, 0.82, 0)
ResetBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
ResetBtn.TextSize = 10
Instance.new("UICorner", ResetBtn)

-- --- 交互逻辑 ---
FlyBtn.MouseButton1Click:Connect(function()
    Flying = not Flying
    if Flying then
        FlyBtn.Text = "ON"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        startVFly()
    else
        FlyBtn.Text = "OFF"
        FlyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        cleanup()
    end
end)

AddBtn.MouseButton1Click:Connect(function()
    Speed = Speed + 20
    SpeedLabel.Text = "Speed: " .. Speed
end)

MinusBtn.MouseButton1Click:Connect(function()
    Speed = math.max(10, Speed - 20)
    SpeedLabel.Text = "Speed: " .. Speed
end)

ResetBtn.MouseButton1Click:Connect(function()
    cleanup()
    if Flying then startVFly() end
end)

-- 重生处理
LocalPlayer.CharacterAdded:Connect(function()
    cleanup()
    task.wait(1.5)
    if Flying then startVFly() end
end)

print("VFly 整合 UI 已加载")